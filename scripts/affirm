#!/usr/bin/env bash
# Affirm the .ok-planner/ artifact layout for the current project.
#
# - Resolves the project root: nearest .git ancestor of $PWD, else $PWD.
# - mkdir -p's the .ok-planner/ subdirectory tree.
# - Overwrites .ok-planner/CLAUDE.md with the canonical template that
#   lives next to this script (skill-owned boilerplate, no merge, no diff).
#
# Idempotent. Re-running on a project already in compliance is a no-op
# at the git level (mkdir -p is silent on existing dirs; writing the
# same bytes leaves the content hash unchanged).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TEMPLATE="${SCRIPT_DIR}/ok-planner-CLAUDE.md"

if [ ! -f "$TEMPLATE" ]; then
    printf 'affirm: template not found at %s\n' "$TEMPLATE" >&2
    exit 1
fi

resolve_root() {
    local dir
    dir="$(pwd)"
    while [ "$dir" != "/" ]; do
        if [ -e "$dir/.git" ]; then
            printf '%s\n' "$dir"
            return
        fi
        dir="$(dirname "$dir")"
    done
    pwd
}

ROOT="$(resolve_root)"
OK_DIR="${ROOT}/.ok-planner"

SUBDIRS=(
    specs
    plans
    sketches
    history/specs
    history/plans
    history/sketches
)

# Only fill in the four design buckets if design/ has already been
# bootstrapped (by discover-design or by hand). Their presence is the
# "design docs exist for this project" gate that other skills key on,
# so affirm must not create design/ itself.
if [ -d "${OK_DIR}/design" ]; then
    SUBDIRS+=(
        design/concepts
        design/stories
        design/decisions
        design/tensions
    )
fi

created=()
for sub in "${SUBDIRS[@]}"; do
    target="${OK_DIR}/${sub}"
    if [ ! -d "$target" ]; then
        mkdir -p "$target"
        created+=("$sub")
    fi
done

cp "$TEMPLATE" "${OK_DIR}/CLAUDE.md"

if [ "${#created[@]}" -eq 0 ]; then
    printf 'Affirmed .ok-planner/ at %s (dirs already present; CLAUDE.md written from template).\n' "$ROOT"
else
    printf 'Affirmed .ok-planner/ at %s (created: %s; CLAUDE.md written from template).\n' "$ROOT" "${created[*]}"
fi
